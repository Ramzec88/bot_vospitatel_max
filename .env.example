# Токен MAX-бота (получить на business.max.ru)
MAX_BOT_TOKEN=

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Supabase PostgreSQL (та же БД, что у Telegram-версии)
DATABASE_URL=

# ID администраторов через запятую (числа)
ADMIN_IDS=

# Никнейм бота в MAX (для генерации реферальных ссылок)
BOT_USERNAME=

# Порт для возможного webhook-режима
PORT=3000
